# ── Zalopay Merchant Analytics — mẫu cấu hình ─────────────────────────
# Copy file này thành `.env` rồi điền API key của BẠN:
#     cp .env.example .env

# API key GreenNode (BẮT BUỘC) — app sẽ không chạy nếu thiếu
GREENNODE_API_KEY=your_key_here
GREENNODE_BASE_URL=https://maas-llm-aiplatform-hcm.api.vngcloud.vn/v1

# (Tuỳ chọn) override model — mặc định đã set trong code
# AGENT1_MODEL=google/gemma-4-31b-it
# AGENT2_MODEL=minimax/minimax-m2.5
# AGENT3_MODEL=qwen/qwen3-5-27b

# (Tuỳ chọn) độ ổn định / web research
# AGENT_MAX_TURNS=16
# FALLBACK_RETRIES=3
# WEB_RESEARCH_ENABLED=true
# MERCHANT_WEBSITE_CRAWL_ENABLED=true
