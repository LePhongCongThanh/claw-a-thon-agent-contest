# ── Env cho AgentBase deploy — truyền qua: runtime.sh ... --env-file .env.agentbase ──
# LƯU Ý: KHÔNG để GREENNODE_CLIENT_ID / GREENNODE_CLIENT_SECRET ở đây —
# AgentBase TỰ INJECT (IAM). Chỉ export chúng ở shell máy bạn lúc DEPLOY.

# LLM key + endpoint (BẮT BUỘC) — nên dùng key tạo qua /agentbase-llm
GREENNODE_API_KEY=your_llm_key_here
GREENNODE_BASE_URL=https://maas-llm-aiplatform-hcm.api.vngcloud.vn/v1

# (Tuỳ chọn) override model / hành vi
# AGENT1_MODEL=google/gemma-4-31b-it
# AGENT2_MODEL=minimax/minimax-m2.5
# AGENT3_MODEL=qwen/qwen3-5-27b
# AGENT_MAX_TURNS=16
# FALLBACK_RETRIES=3
# WEB_RESEARCH_ENABLED=true
# MERCHANT_WEBSITE_CRAWL_ENABLED=true
